# DuckDuckGo MCP Server Environment Configuration

# Transport Mode Options:
# - stdio: Standard input/output (for direct MCP client integration)
# - http: HTTP REST API
# - sse: Server-Sent Events
# - hybrid: Both HTTP and SSE in single process
# - multi: All transports in separate processes
# - auto: Auto-detect best mode based on environment
TRANSPORT_MODE=auto

# Server Configuration
LOG_LEVEL=INFO

# HTTP Transport Configuration
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# SSE Transport Configuration
SSE_HOST=0.0.0.0
SSE_PORT=8081

# Advanced Options
# HTTP_ONLY=true  # Force HTTP only mode
# SSE_ONLY=true   # Force SSE only mode

# MCP Client Detection
# MCP_CLIENT_ID=your-client-id  # For STDIO mode detection